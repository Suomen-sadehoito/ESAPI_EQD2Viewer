<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{B3C4D5E6-F7A8-9012-BCDE-F01234567890}</ProjectGuid>
    <TargetFramework>net48</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>EQD2Viewer.Registration.ITK</RootNamespace>
    <AssemblyName>EQD2Viewer.Registration.ITK</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <PlatformTarget>x64</PlatformTarget>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup>
    <SimpleItkLibPath>$(MSBuildThisFileDirectory)..\lib\SimpleITK\</SimpleItkLibPath>
    <HasSimpleITK>false</HasSimpleITK>
    <HasSimpleITK Condition="Exists('$(SimpleItkLibPath)SimpleITKCSharpManaged.dll')">true</HasSimpleITK>
  </PropertyGroup>

  <ItemGroup Condition="'$(HasSimpleITK)' == 'true'">
    <!-- Managed wrapper: referenced + copied by MSBuild as Private reference -->
    <Reference Include="SimpleITKCSharpManaged">
      <HintPath>$(SimpleItkLibPath)SimpleITKCSharpManaged.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <!-- Native C++ wrappers: copied to output with their original filenames.
         Name varies between SimpleITK versions (SimpleITKCSharp.dll, SimpleITKCSharpNative.dll),
         so copy everything in lib\SimpleITK\ except the managed wrapper. -->
    <None Include="$(SimpleItkLibPath)*.dll"
          Exclude="$(SimpleItkLibPath)SimpleITKCSharpManaged.dll">
      <Link>%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Graceful fallback when SimpleITK isn't deployed: strip the ITK-dependent source files
       so the project still produces a (small, empty) assembly. AppLauncher probes for the
       DLL's type and gracefully disables DIR when the type is missing — this way Debug/Release
       builds never fail just because the dev forgot to install SimpleITK. -->
  <ItemGroup Condition="'$(HasSimpleITK)' != 'true'">
    <Compile Remove="**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\EQD2Viewer.Core\EQD2Viewer.Core.csproj" />
    <ProjectReference Include="..\EQD2Viewer.Registration\EQD2Viewer.Registration.csproj" />
  </ItemGroup>

  <!-- Emit a build-time message so the dev sees the state rather than guessing. -->
  <Target Name="LogSimpleITKState" BeforeTargets="BeforeBuild">
    <Message Importance="high" Text="[Registration.ITK] HasSimpleITK=$(HasSimpleITK) — path: $(SimpleItkLibPath)" />
    <Message Importance="high" Condition="'$(HasSimpleITK)' != 'true'"
             Text="[Registration.ITK] SimpleITK DLLs not found; building empty stub. DIR feature will be disabled at runtime." />
  </Target>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release-WithITK|x64'">
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>

</Project>