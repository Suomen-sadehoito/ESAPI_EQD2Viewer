<Window x:Class="ESAPI_EQD2Viewer.UI.Views.PlanSummationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plan Summation — Re-irradiation Assessment"
        Height="650" Width="750"
        WindowStartupLocation="CenterOwner"
        Background="#222" Foreground="White">
    <Window.Resources>
        <!-- ComboBox dark theme style: forces dark background + white text everywhere -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="DOSE SUMMATION CONFIGURATION" FontWeight="Bold" FontSize="14"
                       Foreground="#FFD700" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap" Foreground="#bbb" FontSize="11" TextAlignment="Center">
                Select plans to sum. For re-irradiation, EQD2 summation correctly accounts
                for different fractionation schedules. Each plan's dose is converted to EQD2
                independently, then summed voxel-by-voxel.
            </TextBlock>
        </StackPanel>

        <!-- Summation method -->
        <Border Grid.Row="1" BorderBrush="#444" BorderThickness="1" CornerRadius="4"
                Padding="10,8" Background="#1a1a1a" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Method:" Foreground="#ccc" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <RadioButton x:Name="RbEQD2" Content=" EQD2 Sum (recommended)"
                             IsChecked="True" Foreground="White" Margin="0,0,20,0"
                             GroupName="SumMethod"/>
                <RadioButton x:Name="RbPhysical" Content=" Physical Sum"
                             Foreground="White" GroupName="SumMethod"/>

                <TextBlock Text="    Global α/β:" Foreground="#ccc" VerticalAlignment="Center" Margin="10,0,6,0"/>
                <TextBox x:Name="TbAlphaBeta" Text="3.0" Width="45" Background="#333"
                         Foreground="White" BorderBrush="#555" Padding="4,2"
                         ToolTip="Initial α/β. Can also be adjusted from the main window slider afterwards."/>
                <TextBlock Text=" Gy" Foreground="#888" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Plan list -->
        <DataGrid Grid.Row="2" x:Name="PlanGrid"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  Background="#111" Foreground="White"
                  RowBackground="#1a1a1a" AlternatingRowBackground="#222"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#333"
                  BorderBrush="#444" FontSize="11"
                  HeadersVisibility="Column" Margin="0,0,0,8">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2a2a2a"/>
                    <Setter Property="Foreground" Value="#ccc"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Include" Width="55"
                    Binding="{Binding IsIncluded, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTemplateColumn Header="Ref" Width="35">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <RadioButton IsChecked="{Binding IsReference, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         GroupName="ReferencePlan" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Course" Width="75" IsReadOnly="True"
                    Binding="{Binding CourseId}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="White"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Plan" Width="75" IsReadOnly="True"
                    Binding="{Binding PlanId}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="White"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Image" Width="65" IsReadOnly="True"
                    Binding="{Binding ImageId}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#888"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Gy" Width="45" IsReadOnly="True"
                    Binding="{Binding TotalDoseGy, StringFormat=F1}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#aaa"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Fx" Width="35"
                    Binding="{Binding NumberOfFractions, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="White"/></Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#333"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Wt" Width="35"
                    Binding="{Binding Weight, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="White"/></Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#333"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- ============================================================
                     REGISTRATION: DataGridTemplateColumn + ComboBox
                     
                     DataGridComboBoxColumn renders as invisible TextBlock in dark theme.
                     This DataGridTemplateColumn contains a real ComboBox that is ALWAYS
                     visible and interactive, not just in edit mode.
                     
                     ItemsSource is bound PER ROW to RelevantRegistrations (filtered by FOR).
                     ============================================================ -->
                <DataGridTemplateColumn Header="Registration" Width="*" MinWidth="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding RelevantRegistrations}"
                                      SelectedValue="{Binding SelectedRegistrationId, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource DarkCombo}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Info panel -->
        <Border Grid.Row="3" BorderBrush="#444" BorderThickness="1" CornerRadius="4"
                Padding="10,6" Background="#1a1a1a" Margin="0,0,0,8">
            <TextBlock TextWrapping="Wrap" Foreground="#999" FontSize="10.5">
                ★ "Ref" = reference plan whose CT is the spatial base grid.
                ★ Registration dropdown is filtered per plan — only relevant registrations shown.
                ★ "None (same CT)" when plans share the same planning CT.
                ★ α/β can also be adjusted later from the main window's EQD2 slider.
            </TextBlock>
        </Border>

        <!-- EQD2 formula -->
        <Border Grid.Row="4" BorderBrush="#555" BorderThickness="1" CornerRadius="4"
                Padding="10,6" Background="#1e2a1e" Margin="0,0,0,12">
            <TextBlock Foreground="#8fbc8f" FontSize="10.5" FontFamily="Consolas" TextAlignment="Center">
                EQD2_total(x,y,z) = Σᵢ [ Dᵢ(x,y,z) × (Dᵢ/nᵢ + α/β) / (2 + α/β) ]
            </TextBlock>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Compute Summation" Width="140" Height="30" Margin="0,0,8,0"
                    Click="Compute_Click" IsDefault="True"
                    Background="#2d5a2d" Foreground="White" FontWeight="SemiBold"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"
                    Foreground="White" Background="#444"/>
        </StackPanel>
    </Grid>
</Window>
