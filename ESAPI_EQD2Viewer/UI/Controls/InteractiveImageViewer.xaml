<UserControl x:Class="ESAPI_EQD2Viewer.UI.Controls.InteractiveImageViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="RootControl">

    <Grid Background="Black"
          ClipToBounds="True"
          PreviewMouseWheel="OnPreviewMouseWheel"
          PreviewMouseDown="OnPreviewMouseDown"
          PreviewMouseMove="OnPreviewMouseMove"
          PreviewMouseUp="OnPreviewMouseUp">

        <Grid x:Name="ImageContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="ImageTranslate" X="0" Y="0" />
                </TransformGroup>
            </Grid.RenderTransform>

            <!-- CT image -->
            <Image Source="{Binding CtImageSource, ElementName=RootControl}" Stretch="None"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Registration overlay (secondary CT for verification) -->
            <Image Source="{Binding OverlayImageSource, ElementName=RootControl}" Stretch="None"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Dose bitmap overlay (Fill + Colorwash) -->
            <Image Source="{Binding DoseImageSource, ElementName=RootControl}" Stretch="None"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Vector isodose contours (Line mode).
                 Canvas needs explicit size matching the CT bitmap dimensions
                 so Path elements are positioned correctly. -->
            <ItemsControl ItemsSource="{Binding ContourLines, ElementName=RootControl}"
                          IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="{Binding CtImageSource.PixelWidth, ElementName=RootControl}"
                                Height="{Binding CtImageSource.PixelHeight, ElementName=RootControl}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Path Data="{Binding Geometry}"
                              Stroke="{Binding Stroke}"
                              StrokeThickness="{Binding StrokeThickness}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

    </Grid>
</UserControl>
